# Copy these names into GitHub Actions secrets or your local shell.
# Fill only the keys you use. Never commit a real .env file with secrets.

# Used by scripts/update_results.py and .github/workflows/update-results.yml
FOOTBALL_DATA_TOKEN=replace_with_football_data_token
FOOTBALL_DATA_COMPETITION_CODE=WC
FOOTBALL_DATA_SEASON=2026

# Optional only if you restore a Codex review workflow later.
OPENAI_API_KEY=replace_with_openai_api_key

# Optional VPS/OBS streaming variable from docs/07-optional-youtube-streaming.md
YOUTUBE_RTMPS_URL=rtmps://a.rtmps.youtube.com/live2/replace_with_stream_key
