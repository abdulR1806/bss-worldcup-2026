# API Token for football-data.org (primary source for update_results.py)
FOOTBALL_DATA_TOKEN=your_api_token_here

# World Cup Competition Details
FOOTBALL_DATA_COMPETITION_CODE=WC
FOOTBALL_DATA_SEASON=2026

# TheSportsDB fallback for update_results.py (used only when football-data.org has no usable score)
THESPORTSDB_API_KEY=123
THESPORTSDB_LEAGUE_ID=4429

# Already Add Env

# Public Google Sheet SKOR panitia used for official leaderboard totals.
# Use /export?format=csv&gid=... for automatic CSV download in GitHub Actions.
OFFICIAL_SCORE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/1Y8KS4EsNpYr8MTv0bUBEsYz-wNN6FaI9ke9J485N05o/export?format=csv&gid=0
# Use a normal share URL as fallback for CSV download and as the public link in the UI.
OFFICIAL_SCORE_SHEET_URL=https://docs.google.com/spreadsheets/d/1Y8KS4EsNpYr8MTv0bUBEsYz-wNN6FaI9ke9J485N05o/edit?usp=sharing
OFFICIAL_SCORE_SHEET_EMBED_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vS1qP5REOzz6gjjbJf02gWWI3MzNnMCAfGfRPdLQQmSxibAMI2J3NJQCSK1SKZEfiUiS01mKxmmWFbA/pubhtml?gid=0&single=true&widget=true&headers=false
