# API Token for football-data.org (primary source for update_results.py)
FOOTBALL_DATA_TOKEN=your_api_token_here

# World Cup Competition Details
FOOTBALL_DATA_COMPETITION_CODE=WC
FOOTBALL_DATA_SEASON=2026

# TheSportsDB fallback for update_results.py (used only when football-data.org has no usable score)
THESPORTSDB_API_KEY=123
THESPORTSDB_LEAGUE_ID=4429

# Already Add Env

# Public Google Sheet SKOR panitia used for official leaderboard totals.
# Use /pubhtml?gid=...&single=true&widget=true&headers=false for the embed value when available.
OFFICIAL_SCORE_SHEET_URL=https://docs.google.com/spreadsheets/d/your-public-sheet-id/edit?usp=sharing
OFFICIAL_SCORE_SHEET_EMBED_URL=https://docs.google.com/spreadsheets/d/e/your-published-sheet-id/pubhtml?gid=0&single=true&widget=true&headers=false
